@base <https://w3id.org/tre/license/> .

@prefix fsl: <https://w3id.org/tre/license/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dpv: <https://w3id.org/dpv#> .
@prefix duodrl: <https://w3id.org/duodrl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix loc: <https://w3id.org/dpv/loc#> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sane: <https://w3id.org/tre/instance/sane#> .
@prefix schema: <https://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix tre: <https://w3id.org/tre/vocabulary/v0#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/tre/license/five_safes_license>
    a foaf:Document ;
    rdfs:label "ODISSEI Five Safes license"@en ;
    dct:description "ODRL version of a standardised set of conditions for accessing and using sensitive datasets in a Trusted Research Environment (TRE) such as SANE, according to the Five Safes principles."@en ;
    schema:version "1.1.0" ;
    owl:versionInfo "1.1.0" ;
    owl:versionIRI <https://w3id.org/tre/license/five_safes_license_v1.1> ;
    dct:isFormatOf <https://doi.org/10.5281/zenodo.18456775> ;
    dct:created "2026-02-25"^^xsd:date ;
    dct:modified "2026-07-17"^^xsd:date ;
    skos:scopeNote "To refer to version 1 of the Five Safes License, use the Zenodo identifier, also for ODRL parsing."@en ;
    dct:creator <https://surf.nl> , <https://odissei-data.nl> ;
    dct:contributor "Freek Dijkstra" , "Lucas van der Meer" ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> .

<https://doi.org/10.5281/zenodo.18456775>
    a odrl:Offer ;
    rdfs:label "ODISSEI Five Safes license"@en ;
    dct:description "A standardised set of conditions for accessing and using sensitive datasets in a Trusted Research Environment (TRE) such as SANE, according to the Five Safes principles."@en ;
    schema:version "v1.01" ;
    dct:isVersionOf <https://doi.org/10.5281/zenodo.18456774> ;
    dct:hasFormat <https://w3id.org/tre/license/five_safes_license> ;
    skos:scopeNote "To refer to version 1 of the Five Safes License, use this identifier, also for ODRL parsing."@en ;
    odrl:profile <https://w3id.org/tre/vocabulary/v0> ;
    odrl:permission [
        odrl:action fsl:action-analyse-in-sane ;
        odrl:assignee fsl:assignee-odissei-member ;
        odrl:assignee fsl:assignee-located-europe-economic-area ;
        odrl:assignee fsl:assignee-affiliation-employee-faculty ;
        odrl:constraint fsl:constraint-elapsed-time ;
        odrl:duty fsl:duty-attribution ;
        odrl:duty fsl:duty-declare-purpose-non-commercial ;
        odrl:duty fsl:duty-accept-terms ;
    ] ;
    odrl:prohibition [
        odrl:action odrl:distribute
    ] .

# Refinement of the tre:analyse action: only inside SANE.
fsl:action-analyse-in-sane
    rdf:value tre:analyse ;
    odrl:refinement [
        odrl:leftOperand odrl:virtualLocation ;
        odrl:operator odrl:eq ;
        odrl:rightOperand <https://w3id.org/tre/instance/sane#SANE> ;
    ] .

# Refinement of the assignee: ODISSEI member.
fsl:assignee-odissei-member
    a odrl:PartyCollection ;
    odrl:source <https://odissei-data.nl/> .

# Refinement of the assignee: located in the European Economic Area.
fsl:assignee-located-europe-economic-area
    a odrl:PartyCollection ;
    odrl:refinement [
        odrl:leftOperand odrl:spatial ;
        odrl:operator odrl:isAnyOf ;
        odrl:rightOperand loc:EEA ;
    ] .

# Refinement of the assignee: employee or faculty affiliation.
fsl:assignee-affiliation-employee-faculty
    a odrl:PartyCollection ;
    odrl:refinement [
        odrl:leftOperand <urn:oid:1.3.6.1.4.1.5923.1.1.1.1> ;
        odrl:operator odrl:isAnyOf ;
        odrl:rightOperand "employee", "faculty" ;
    ] .

# Constraint on the permission: access expires after 3 months.
fsl:constraint-elapsed-time
    odrl:leftOperand odrl:elapsedTime ;
    odrl:operator odrl:lteq ;
    odrl:rightOperand "P3M"^^xsd:duration .

# Duty: attribute the dataset.
fsl:duty-attribution
    odrl:action odrl:attribute .

# Duty: obtain ethical approval.
# Unused by Five Safes License
fsl:duty-provide-ethical-approval
    odrl:action duodrl:ProvideEthicalApproval .

# Duty: declare intended purpose, restricted to non-commercial research.
fsl:duty-declare-purpose-non-commercial
    odrl:action [
        rdf:value tre:declareIntendedPurpose ;
        odrl:refinement [
            odrl:leftOperand odrl:purpose ;
            odrl:operator odrl:isAnyOf ;
            odrl:rightOperand dpv:NonCommercialResearch ;
        ] ;
    ] .

# Duty: provide access purpose, between 10 and 150 words.
# Unused by Five Safes License
fsl:duty-provide-purpose
    odrl:action [
        rdf:value tre:provideAccessPurpose ;
        odrl:refinement [
            odrl:leftOperand schema:wordCount ;
            odrl:operator odrl:gteq ;
            odrl:rightOperand 10 ;
        ] , [
            odrl:leftOperand schema:wordCount ;
            odrl:operator odrl:lteq ;
            odrl:rightOperand 150 ;
        ] ;
    ] .

# Duty: accept the terms of use.
fsl:duty-accept-terms
    odrl:action tre:acceptTerms .
