  <odrl:Offer rdf:about="https://doi.org/10.5281/zenodo.18456775">
    <rdfs:label xml:lang="en">ODISSEI Five Safes license</rdfs:label>
    <dct:description xml:lang="en">A standardised set of conditions for accessing and using sensitive datasets in a Trusted Research Environment (TRE) such as SANE, according to the Five Safes principles.</dct:description>
    <schema:version>v1.01</schema:version>
    <dct:isVersionOf rdf:resource="https://doi.org/10.5281/zenodo.18456774"/>
    <dct:hasFormat>
      <foaf:Document rdf:about="https://w3id.org/tre/license/five_safes_license">
        <rdfs:label xml:lang="en">ODISSEI Five Safes license</rdfs:label>
        <dct:description xml:lang="en">ODRL version of a standardised set of conditions for accessing and using sensitive datasets in a Trusted Research Environment (TRE) such as SANE, according to the Five Safes principles.</dct:description>
        <schema:version>1.1.0</schema:version>
        <owl:versionInfo>1.1.0</owl:versionInfo>
        <owl:versionIRI rdf:resource="https://w3id.org/tre/license/five_safes_license_v1.1"/>
        <dct:isFormatOf rdf:resource="https://doi.org/10.5281/zenodo.18456775"/>
        <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-25</dct:created>
        <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-07-17</dct:modified>
        <skos:scopeNote xml:lang="en">To refer to version 1 of the Five Safes License, use the Zenodo identifier, also for ODRL parsing.</skos:scopeNote>
        <dct:creator rdf:resource="https://surf.nl"/>
        <dct:creator rdf:resource="https://odissei-data.nl"/>
        <dct:contributor>Freek Dijkstra</dct:contributor>
        <dct:contributor>Lucas van der Meer</dct:contributor>
        <dct:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
      </foaf:Document>
    </dct:hasFormat>
    <skos:scopeNote xml:lang="en">To refer to version 1 of the Five Safes License, use this identifier, also for ODRL parsing.</skos:scopeNote>
