    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "The SURF Research Cloud service, through which users can provision a SANE Trusted Research Environment."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#editorialNote": [
      {
        "@language": "en",
        "@value": "A general RDF description of the SURF Research Cloud service does not yet exist, as of 2026-07-17."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "Only use sane:SRC in the context of a tre:TREService. It is not intended as an overall description of the SURF Research Cloud service."
