  {
    "@id": "https://w3id.org/tre/instance/sane#SANE",
    "@type": [
      "https://w3id.org/tre/vocabulary/v0#TRE",
      "http://www.w3.org/ns/odrl/2/RightOperand"
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "https://w3id.org/tre/instance/sane"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "SANE"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "SURF Secure Analysis Environment. A Trusted Research Environment (TRE) that allows analysis on a (confidential) dataset, without the data leaving the environment. The output is released after a check by the data provider."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "Intended for use as the odrl:rightOperand of a Refinement/Constraint whose odrl:leftOperand is odrl:virtualLocation."
      }
    ],
    "https://schema.org/potentialAction": [
      {
        "@id": "https://w3id.org/tre/vocabulary/v0#analyse"
      }
    ],
    "https://schema.org/provider": [
      {
        "@id": "https://surf.nl"
      }
    ],
    "https://w3id.org/dpv#hasDataProcessor": [
      {
        "@id": "https://surf.nl"
      }
    ],
    "https://w3id.org/dpv#hasLocation": [
      {
        "@id": "https://w3id.org/dpv/loc#NL"
      }
    ]
  },
