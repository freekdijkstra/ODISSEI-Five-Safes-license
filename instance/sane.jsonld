      }
    ],
    "http://www.w3.org/2004/02/skos/core#definition": [
      {
        "@language": "en",
        "@value": "Remote desktop environment that provides tool to run an analysis on a (confidential) dataset. The environment does not have Internet access, and the result of the analysis is send to the data provider for verification."
      }
    ],
    "http://www.w3.org/2004/02/skos/core#scopeNote": [
      {
        "@language": "en",
        "@value": "Intended for use as the odrl:rightOperand of a Refinement/Constraint whose odrl:leftOperand is odrl:virtualLocation."
      }
    ],
    "https://schema.org/potentialAction": [
      {
        "@id": "https://w3id.org/tre/vocabulary/v0#analyse"
      }
    ],
    "https://schema.org/provider": [
      {
        "@id": "https://surf.nl"
      }
    ],
