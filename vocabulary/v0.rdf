<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
  xmlns:odrl="http://www.w3.org/ns/odrl/2/"
  xmlns:dct="http://purl.org/dc/terms/"
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
  xmlns:skos="http://www.w3.org/2004/02/skos/core#"
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:schema="https://schema.org/"
>
  <odrl:Action rdf:about="https://w3id.org/tre/vocabulary/v0#provideAccessPurpose">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:isDefinedBy>
      <owl:Ontology rdf:about="https://w3id.org/tre/vocabulary/v0">
        <rdfs:label xml:lang="en">TRE Vocabulary</rdfs:label>
        <dct:description xml:lang="en">An ODRL Profile that defines the terms needed to write access policies for Trusted Research Environments (TREs), such as the ODISSEI Five Safes License.</dct:description>
        <owl:versionInfo>0.5</owl:versionInfo>
        <owl:versionIRI rdf:resource="https://w3id.org/tre/vocabulary/v0"/>
        <dct:license rdf:resource="https://creativecommons.org/licenses/by-nc/4.0/"/>
        <dct:creator rdf:resource="https://surf.nl"/>
        <dct:creator rdf:resource="https://odissei-data.nl"/>
        <dct:contributor>Freek Dijkstra</dct:contributor>
        <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-25</dct:created>
        <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-07-17</dct:modified>
        <dct:hasFormat rdf:resource="https://w3id.org/tre/vocabulary/v0.ttl"/>
        <dct:hasFormat rdf:resource="https://w3id.org/tre/vocabulary/v0.jsonld"/>
        <dct:hasFormat rdf:resource="https://w3id.org/tre/vocabulary/v0.rdf"/>
        <dct:hasFormat rdf:resource="https://w3id.org/tre/vocabulary/v0.md"/>
        <dct:requires rdf:resource="urn:oid:1.3.6.1.4.1.5923.1.1.1.1"/>
        <dct:requires rdf:resource="https://w3id.org/dpv#CommercialResearch"/>
        <dct:requires rdf:resource="https://w3id.org/dpv#NonCommercialResearch"/>
        <dct:requires rdf:resource="https://w3id.org/duodrl#ProvideEthicalApproval"/>
      </owl:Ontology>
    </rdfs:isDefinedBy>
    <odrl:includedIn rdf:resource="http://www.w3.org/ns/odrl/2/inform"/>
    <rdfs:label>Provide access purpose</rdfs:label>
    <skos:definition xml:lang="en">The duty to provide a description of the purpose for which access is requested. Specialisation of odrl:inform.</skos:definition>
    <skos:scopeNote xml:lang="en">Intended to use as a Duty</skos:scopeNote>
  </odrl:Action>
  <odrl:Action rdf:about="https://w3id.org/tre/vocabulary/v0#declareIntendedPurpose">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/tre/vocabulary/v0"/>
    <odrl:includedIn rdf:resource="http://www.w3.org/ns/odrl/2/inform"/>
    <rdfs:label>Declare intended purpose</rdfs:label>
    <skos:definition xml:lang="en">The duty to declare the intended purpose of access. Specialisation of odrl:inform.</skos:definition>
    <skos:scopeNote xml:lang="en">Intended to use as a Duty</skos:scopeNote>
  </odrl:Action>
  <rdfs:Class rdf:about="https://w3id.org/tre/vocabulary/v0#TREService">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/tre/vocabulary/v0"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/dcat#DataService"/>
    <rdfs:subClassOf rdf:resource="https://schema.org/Service"/>
    <rdfs:label>TRE Service</rdfs:label>
    <skos:definition xml:lang="en">A Service that provides a trusted research environment (TRE).</skos:definition>
    <skos:scopeNote xml:lang="en">Not directly used in ODRL constraints. Use tre:TRE instead.</skos:scopeNote>
    <schema:serviceOutput rdf:resource="https://w3id.org/tre/vocabulary/v0#TRE"/>
  </rdfs:Class>
  <owl:NegativePropertyAssertion rdf:nodeID="tre-no-distribute">
    <owl:sourceIndividual rdf:resource="https://w3id.org/tre/vocabulary/v0#TRE"/>
    <owl:assertionProperty rdf:resource="https://schema.org/potentialAction"/>
    <owl:targetIndividual rdf:resource="http://www.w3.org/ns/odrl/2/distribute"/>
  </owl:NegativePropertyAssertion>
  <odrl:Action rdf:about="https://w3id.org/tre/vocabulary/v0#acceptTerms">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/tre/vocabulary/v0"/>
    <odrl:includedIn rdf:resource="http://www.w3.org/ns/odrl/2/obtainConsent"/>
    <rdfs:label>Accept terms of use</rdfs:label>
    <skos:definition xml:lang="en">The duty to accept the terms of use. Specialisation of odrl:obtainConsent.</skos:definition>
    <skos:scopeNote xml:lang="en">Intended to use as a Duty</skos:scopeNote>
  </odrl:Action>
  <odrl:LeftOperand rdf:about="urn:oid:1.3.6.1.4.1.5923.1.1.1.1">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:isDefinedBy rdf:resource="https://software.internet2.edu/eduperson/internet2-mace-dir-eduperson-201602.html#eduPersonAffiliation"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/tre/vocabulary/v0"/>
    <rdfs:label>eduPersonAffiliation</rdfs:label>
    <skos:definition xml:lang="en">Specifies the person's relationship(s) to the institution in broad categories. Permissible values are: faculty, student, staff, alum, member, affiliate, employee, library-walk-in.</skos:definition>
    <skos:scopeNote xml:lang="en">Intended to use as a LeftOperand in a refinement of the odrl:assignee.</skos:scopeNote>
    <skos:editorialNote xml:lang="en">This OID is defined as an SAML/LDAP attribute. The identifier is replicated here so it can be used in a semantic web context.</skos:editorialNote>
    <skos:broader rdf:resource="http://www.w3.org/ns/org#Role"/>
  </odrl:LeftOperand>
  <odrl:Action rdf:about="https://w3id.org/tre/vocabulary/v0#analyse">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/tre/vocabulary/v0"/>
    <odrl:includedIn rdf:resource="http://www.w3.org/ns/odrl/2/grantUse"/>
    <rdfs:label xml:lang="en">Run an analysis on a dataset</rdfs:label>
    <skos:definition xml:lang="en">The permission of running an analysis on a dataset. Specialisation of odrl:grantUse.</skos:definition>
    <skos:scopeNote xml:lang="en">Intended to use as a Permission</skos:scopeNote>
  </odrl:Action>
  <rdfs:Class rdf:about="https://w3id.org/tre/vocabulary/v0#TRE">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/tre/vocabulary/v0"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/tech#Platform"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv#InformationFlowControl"/>
    <rdfs:label>Trusted Research Environment</rdfs:label>
    <skos:altLabel>Secure Processing Environment</skos:altLabel>
    <skos:definition xml:lang="en">A controlled compute environment in which permitted analyses on a dataset may be performed, without the data leaving the environment.</skos:definition>
    <skos:scopeNote xml:lang="en">Instances of TRE are intended to be used as the odrl:rightOperand of a Constraint whose odrl:leftOperand is odrl:virtualLocation.</skos:scopeNote>
    <schema:potentialAction rdf:resource="https://w3id.org/tre/vocabulary/v0#analyse"/>
  </rdfs:Class>
</rdf:RDF>
